---
const annoCorrente = new Date().getFullYear();

const navColonne = [
  {
    titolo: "La residenza",
    links: [
      { label: "Chi siamo",    href: "#chi-siamo" },
      { label: "La vita qui",  href: "#vita-qui" },
      { label: "Gli spazi",    href: "#spazi" },
      { label: "Il team",      href: "#team" },
    ],
  },
  {
    titolo: "Informazioni",
    links: [
      { label: "Attività",          href: "#attivita" },
      { label: "Testimonianze",     href: "#testimonianze" },
      { label: "Prenota una visita",href: "#prenota-visita" },
      { label: "Contatti",          href: "#contatti" },
    ],
  },
  {
    titolo: "Legale",
    links: [
      { label: "Privacy Policy", href: "/privacy-policy" },
      { label: "Cookie Policy",  href: "/cookie-policy" },
    ],
  },
];
---

<footer class="footer">

  <!-- Corpo footer -->
  <div class="footer-body">
    <div class="section-wrapper">
      <div class="footer-grid">

        <!-- Brand column -->
        <div class="footer-brand">
          <a href="#home" class="footer-logo">
            <div class="footer-logo-icon">
              <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                <path d="M20 8 C14 8 10 13 10 18 C10 25 16 28 20 32 C24 28 30 25 30 18 C30 13 26 8 20 8Z" fill="currentColor" opacity="0.8"/>
                <circle cx="20" cy="18" r="4" fill="white" opacity="0.9"/>
              </svg>
            </div>
            <div>
              <p class="footer-logo-sopra">Cooperativa Sociale</p>
              <p class="footer-logo-nome">Giovanni Paolo II</p>
            </div>
          </a>

          <p class="footer-tagline">
            Una comunità accogliente dove ogni ospite è di casa.
            Dal 1987 con dedizione, calore umano e spirito cooperativo.
          </p>

          <!-- Social -->
          <div class="footer-social">
            <a href="https://instagram.com" target="_blank" rel="noopener" class="footer-social-link" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <a href="https://facebook.com" target="_blank" rel="noopener" class="footer-social-link" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Nav colonne -->
        {navColonne.map(({ titolo, links }) => (
          <div class="footer-nav-col">
            <h3 class="footer-nav-titolo">{titolo}</h3>
            <ul class="footer-nav-lista">
              {links.map(({ label, href }) => (
                <li>
                  <a href={href} class="footer-nav-link">{label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <!-- Contatti rapidi -->
        <div class="footer-contatti-rapidi">
          <h3 class="footer-nav-titolo">Vieni a trovarci</h3>
          <div class="footer-contatti-lista">
            <p class="footer-contatto-item">
              📍 Via Giovanni Paolo II, 14<br />25100 Brescia (BS)
            </p>
            <a href="tel:+390300000000" class="footer-contatto-link">
              📞 +39 030 000 0000
            </a>
            <a href="mailto:info@cooperativagp2.it" class="footer-contatto-link">
              ✉️ info@cooperativagp2.it
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Nota importante -->
  <div class="footer-nota-wrap">
    <div class="section-wrapper">
      <p class="footer-nota">
        ℹ️ La nostra struttura non è una RSA (Residenza Sanitaria Assistenziale).
        Per esigenze di assistenza medica specialistica, rivolgiti al tuo medico di base
        o alle strutture sanitarie competenti del territorio.
      </p>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="section-wrapper">
      <div class="footer-bottom-inner">
        <p class="footer-copyright">
          © {annoCorrente} Cooperativa Sociale Giovanni Paolo II —
          P.IVA 01234567890 · C.F. 01234567890
        </p>
        <div class="footer-bottom-links">
          <a href="/privacy-policy" class="footer-bottom-link">Privacy Policy</a>
          <span class="footer-bottom-sep">·</span>
          <a href="/cookie-policy" class="footer-bottom-link">Cookie Policy</a>
        </div>
      </div>
    </div>
  </div>

</footer>

<style>
  .footer {
    background-color: var(--color-marrone);
  }

  /* ── Body ── */
  .footer-body {
    padding-block: 5rem 4rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr; gap: 2.5rem; }
  }

  /* ── Brand ── */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }
  .footer-logo-icon {
    color: var(--color-terracotta);
    flex-shrink: 0;
  }
  .footer-logo-sopra {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    font-weight: 600;
    margin: 0;
  }
  .footer-logo-nome {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-avorio);
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: rgba(247, 243, 236, 0.55);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 22rem;
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: 0.75rem;
  }
  .footer-social-link {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 0.5rem;
    background-color: rgba(247, 243, 236, 0.08);
    color: rgba(247, 243, 236, 0.65);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .footer-social-link:hover {
    background-color: var(--color-terracotta);
    color: white;
  }

  /* ── Nav colonne ── */
  .footer-nav-titolo {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    margin-bottom: 1rem;
  }
  .footer-nav-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-nav-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: rgba(247, 243, 236, 0.65);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-nav-link:hover {
    color: var(--color-avorio);
  }

  /* ── Contatti rapidi ── */
  .footer-contatti-lista {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .footer-contatto-item {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: rgba(247, 243, 236, 0.65);
    line-height: 1.65;
    margin: 0;
  }
  .footer-contatto-link {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: rgba(247, 243, 236, 0.65);
    text-decoration: none;
    display: block;
    transition: color 0.2s ease;
  }
  .footer-contatto-link:hover {
    color: var(--color-avorio);
  }

  /* ── Nota ── */
  .footer-nota-wrap {
    border-top: 1px solid rgba(247, 243, 236, 0.08);
    padding-block: 1.5rem;
  }
  .footer-nota {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: rgba(247, 243, 236, 0.40);
    line-height: 1.65;
    max-width: 60rem;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    border-top: 1px solid rgba(247, 243, 236, 0.08);
    padding-block: 1.25rem;
  }
  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }
  @media (min-width: 640px) {
    .footer-bottom-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
  .footer-copyright {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: rgba(247, 243, 236, 0.35);
    margin: 0;
  }
  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-bottom-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: rgba(247, 243, 236, 0.35);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-bottom-link:hover {
    color: rgba(247, 243, 236, 0.7);
  }
  .footer-bottom-sep {
    color: rgba(247, 243, 236, 0.2);
    font-size: 0.8rem;
  }
</style>