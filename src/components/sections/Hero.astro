---
const heroImage = "https://images.unsplash.com/photo-1447752875215-b2761acb3c5d?w=1800&q=80";

const stats = [
  { numero: "37+", label: "anni di storia" },
  { numero: "45",  label: "ospiti accolti" },
  { numero: "30+", label: "persone nel team" },
];
---

<section
  id="home"
  class="hero-section"
  aria-label="Benvenuto nella Cooperativa Sociale Giovanni Paolo II"
>
  <!-- Immagine di sfondo -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-overlay"></div>
  </div>

  <!-- Contenuto -->
  <div class="hero-content">
    <div class="hero-inner">

      <!-- Badge -->
      <div class="hero-badge-wrap anim-1">
        <span class="hero-badge">✦ Cooperativa Sociale dal 1987</span>
      </div>

      <!-- Headline -->
      <h1 class="hero-title anim-2">
        Una casa dove<br />
        <em class="hero-title-em">la vita continua<br />a fiorire</em>
      </h1>

      <!-- Sottotitolo -->
      <p class="hero-sub anim-3">
        Dal 1987 accogliamo ogni ospite come parte della nostra famiglia.
        Una comunità vera, costruita giorno dopo giorno con dedizione,
        calore umano e lo spirito cooperativo che ci contraddistingue.
      </p>

      <!-- CTA -->
      <div class="hero-cta anim-4">
        <a href="#prenota-visita" class="cta-primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          Prenota una visita
        </a>
        <a href="#chi-siamo" class="cta-secondary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          Scopri chi siamo
        </a>
      </div>

      <!-- Stats -->
      <div class="hero-stats anim-5">
        {stats.map(({ numero, label }) => (
          <div class="hero-stat">
            <span class="hero-stat-num">{numero}</span>
            <span class="hero-stat-label">{label}</span>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-label">Scorri</span>
    <div class="scroll-line"></div>
  </div>

</section>

<style>
  /* ── Layout ── */
  .hero-section {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('https://images.unsplash.com/photo-1447752875215-b2761acb3c5d?w=1800&q=80');
    background-size: cover;
    background-position: center;
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(74, 55, 40, 0.75) 0%,
      rgba(196, 123, 90, 0.45) 55%,
      rgba(74, 55, 40, 0.30) 100%
    );
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    padding-top: 8rem;
    padding-bottom: 6rem;
    padding-inline: 1.5rem;
  }
  .hero-inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  /* ── Badge ── */
  .hero-badge-wrap { margin-bottom: 2rem; }
  .hero-badge {
    display: inline-block;
    background-color: rgba(212, 168, 67, 0.2);
    border: 1px solid rgba(212, 168, 67, 0.45);
    color: #E8C97A;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 1.1rem;
    border-radius: 9999px;
    backdrop-filter: blur(8px);
  }

  /* ── Title ── */
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    font-weight: 300;
    line-height: 1.15;
    color: #FAF6EE;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .hero-title-em {
    font-style: italic;
    font-weight: 600;
    color: #E8C97A;
  }

  /* ── Subtitle ── */
  .hero-sub {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(247, 243, 236, 0.88);
    max-width: 36rem;
    line-height: 1.8;
    margin-top: 1.5rem;
  }

  /* ── CTA ── */
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background-color: var(--color-terracotta);
    color: white;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.05rem;
    padding: 0.9rem 1.9rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 24px -4px rgba(196, 123, 90, 0.5);
  }
  .cta-primary:hover {
    background-color: var(--color-terracotta-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px -4px rgba(196, 123, 90, 0.6);
  }
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border: 2px solid rgba(247, 243, 236, 0.65);
    color: #FAF6EE;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.9rem 1.9rem;
    border-radius: 9999px;
    text-decoration: none;
    backdrop-filter: blur(8px);
    background-color: rgba(247, 243, 236, 0.08);
    transition: background-color 0.3s ease, transform 0.3s ease;
  }
  .cta-secondary:hover {
    background-color: rgba(247, 243, 236, 0.18);
    transform: translateY(-2px);
  }

  /* ── Stats ── */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(247, 243, 236, 0.15);
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hero-stat-num {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    color: #E8C97A;
    line-height: 1;
  }
  .hero-stat-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: rgba(247, 243, 236, 0.65);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Scroll indicator ── */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .scroll-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(247, 243, 236, 0.55);
  }
  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(247,243,236,0.55), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  /* ── Animazioni entrata ── */
  .anim-1, .anim-2, .anim-3, .anim-4, .anim-5 {
    opacity: 0;
    transform: translateY(22px);
    animation: heroFadeUp 0.8s ease-out forwards;
  }
  .anim-1 { animation-delay: 0.2s; }
  .anim-2 { animation-delay: 0.45s; }
  .anim-3 { animation-delay: 0.7s; }
  .anim-4 { animation-delay: 0.95s; }
  .anim-5 { animation-delay: 1.2s; }

  @keyframes heroFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }
</style>