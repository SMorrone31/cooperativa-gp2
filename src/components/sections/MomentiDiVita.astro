---
// Elfsight widget embed — il codice reale va inserito dopo aver creato
// il widget su https://elfsight.com (piano gratuito disponibile)
// Per ora mostriamo un placeholder visivo con istruzioni
const elfsightCode = "fbe01526-0342-4dcb-bf9b-294b738410f4"; // es: "e9f1a2b3-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
---

<section id="momenti" class="momenti-section">
  <div class="section-wrapper">

    <!-- Header -->
    <div class="momenti-header reveal">
      <span class="tag-pill">Momenti di vita</span>
      <h2 class="section-title" style="margin-top: 1rem;">
        La nostra vita quotidiana,<br />
        <em style="font-style: italic; color: var(--color-terracotta);">in tempo reale.</em>
      </h2>
      <p class="section-subtitle" style="margin-top: 1.25rem;">
        Seguici su Instagram e Facebook per vedere cosa succede ogni giorno nella nostra residenza —
        feste, attività, sorrisi, piccoli momenti che fanno grande una comunità.
      </p>
    </div>

    <!-- Elfsight widget o placeholder -->
    {elfsightCode ? (
    <div class="momenti-widget reveal">
        <script src="https://elfsightcdn.com/platform.js" async></script>
        <div class={`elfsight-app-${elfsightCode}`} data-elfsight-app-lazy></div>
    </div>
    ) : (
      <!-- Placeholder visivo fino a configurazione Elfsight -->
      <div class="momenti-placeholder reveal">
        <div class="momenti-placeholder-grid">
          {[
            { emoji: "🎂", testo: "Buon compleanno Giuseppina! 90 candeline e un sorriso bellissimo 🎉", ora: "2 ore fa" },
            { emoji: "🌱", testo: "Stamattina nell'orto abbiamo raccolto i primi pomodori della stagione 🍅", ora: "Ieri" },
            { emoji: "🎵", testo: "Mercoledì di musica! Il fisarmonicista Gianni ha fatto ballare tutti ✨", ora: "3 giorni fa" },
            { emoji: "🐾", testo: "Visita speciale oggi: Pallino e Birba hanno portato un sacco di coccole 🐕", ora: "4 giorni fa" },
            { emoji: "🎨", testo: "I dipinti del laboratorio di questa settimana — che talenti nascosti!", ora: "5 giorni fa" },
            { emoji: "☀️", testo: "Colazione in giardino con questo sole meraviglioso. Buongiorno a tutti! 🌸", ora: "1 settimana fa" },
          ].map((post) => (
            <div class="momenti-post">
              <div class="momenti-post-emoji">{post.emoji}</div>
              <p class="momenti-post-testo">{post.testo}</p>
              <span class="momenti-post-ora">{post.ora}</span>
            </div>
          ))}
        </div>

        <!-- Nota configurazione -->
        <div class="momenti-setup-nota">
          <p>
            📱 <strong>Per attivare il feed social reale:</strong> crea un account su
            <a href="https://elfsight.com" target="_blank" rel="noopener">elfsight.com</a>,
            collega il profilo Instagram o Facebook della cooperativa, copia il codice widget
            e incollalo nella variabile <code>elfsightCode</code> in questo file.
          </p>
        </div>
      </div>
    )}

    <!-- Link social -->
    <div class="momenti-social reveal">
      <a href="https://instagram.com" target="_blank" rel="noopener" class="momenti-social-btn momenti-social-btn--ig">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        Seguici su Instagram
      </a>
      <a href="https://facebook.com" target="_blank" rel="noopener" class="momenti-social-btn momenti-social-btn--fb">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Seguici su Facebook
      </a>
    </div>

  </div>
</section>

<style>
  .momenti-section {
    padding-block: 7rem;
    background-color: var(--color-avorio);
  }

  .momenti-header {
    max-width: 52rem;
    margin-bottom: 4rem;
  }

  /* ── Widget ── */
  .momenti-widget {
    margin-bottom: 3rem;
  }

  /* ── Placeholder ── */
  .momenti-placeholder {
    margin-bottom: 3rem;
  }
  .momenti-placeholder-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 640px) {
    .momenti-placeholder-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .momenti-placeholder-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .momenti-post {
    background-color: white;
    border-radius: 1.25rem;
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--color-marrone) 8%, transparent);
    box-shadow: 0 2px 16px -4px rgba(74, 55, 40, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .momenti-post:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px -4px rgba(74, 55, 40, 0.14);
  }
  .momenti-post-emoji {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .momenti-post-testo {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-marrone);
    margin-bottom: 1rem;
  }
  .momenti-post-ora {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--color-marrone) 45%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .momenti-setup-nota {
    background-color: color-mix(in srgb, var(--color-ocra) 12%, transparent);
    border: 1px dashed color-mix(in srgb, var(--color-ocra) 40%, transparent);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-marrone);
    line-height: 1.65;
  }
  .momenti-setup-nota a {
    color: var(--color-terracotta);
    font-weight: 600;
    text-decoration: underline;
  }
  .momenti-setup-nota code {
    background-color: rgba(74,55,40,0.08);
    padding: 0.1rem 0.4rem;
    border-radius: 0.3rem;
    font-size: 0.85rem;
  }

  /* ── Social buttons ── */
  .momenti-social {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .momenti-social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.97rem;
    padding: 0.85rem 1.75rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .momenti-social-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -4px rgba(74, 55, 40, 0.2);
  }
  .momenti-social-btn--ig {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: white;
  }
  .momenti-social-btn--fb {
    background-color: #1877F2;
    color: white;
  }
</style>