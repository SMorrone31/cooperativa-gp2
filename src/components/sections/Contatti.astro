---
---

<section id="contatti" class="contatti-section">
  <div class="section-wrapper">

    <!-- Header -->
    <div class="contatti-header reveal">
      <span class="tag-pill">Contatti</span>
      <h2 class="section-title" style="margin-top: 1rem;">
        Siamo qui.<br />
        <em style="font-style: italic; color: var(--color-salvia-dark);">Scrivici o chiamaci.</em>
      </h2>
    </div>

    <div class="contatti-grid">

      <!-- Info contatto -->
      <div class="contatti-info reveal">

        <div class="contatti-info-lista">
          {[
            {
              icona: "📍",
              titolo: "Indirizzo",
              testo: "Corso Umberto I,\n85010 Campomaggiore (PZ)",
            },
            {
              icona: "📞",
              titolo: "Telefono",
              testo: "+39 030 000 0000",
              href: "tel:+390300000000",
            },
            {
              icona: "✉️",
              titolo: "Email",
              testo: "info@cooperativagp2.it",
              href: "mailto:info@cooperativagp2.it",
            },
            {
              icona: "🕐",
              titolo: "Orari ufficio",
              testo: "Lun–Ven 8:30–17:30\nSabato 9:00–12:00",
            },
          ].map(({ icona, titolo, testo, href }) => (
            <div class="contatti-info-item">
              <div class="contatti-info-icona">{icona}</div>
              <div>
                <p class="contatti-info-titolo">{titolo}</p>
                {href ? (
                  <a href={href} class="contatti-info-link">
                    {testo}
                  </a>
                ) : (
                  <p class="contatti-info-testo">{testo}</p>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Mappa Google -->
        <div class="contatti-mappa reveal">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3030.926802891432!2d16.069056775076326!3d40.56529364658544!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1338edb2052fbbfb%3A0x86a31476a474b32c!2sGiovanni%20Paolo%20II%20societ%C3%A0%20cooperativa%20sociale!5e0!3m2!1sit!2sit!4v1776524990016!5m2!1sit!2sit"
            width="100%"
            height="280"
            style="border:0; border-radius: 1rem; display: block;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Posizione della Cooperativa Sociale Giovanni Paolo II su Google Maps"
          ></iframe>
        </div>

      </div>

      <!-- Form contatto generico -->
      <div class="contatti-form-wrap reveal">
        <form
          name="contatti"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="contatti-form"
        >
          <input type="hidden" name="form-name" value="contatti" />
          <p style="display:none;">
            <label>Non compilare: <input name="bot-field" /></label>
          </p>

          <h3 class="contatti-form-titolo">Mandaci un messaggio</h3>

          <div class="form-group">
            <label class="form-label" for="cont-nome">Nome e cognome *</label>
            <input
              type="text"
              id="cont-nome"
              name="nome"
              required
              placeholder="Mario Rossi"
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="cont-email">Email *</label>
            <input
              type="email"
              id="cont-email"
              name="email"
              required
              placeholder="mario@email.it"
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="cont-tel">Telefono</label>
            <input
              type="tel"
              id="cont-tel"
              name="telefono"
              placeholder="+39 333 000 0000"
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="cont-oggetto">Oggetto *</label>
            <select id="cont-oggetto" name="oggetto" required class="form-input">
              <option value="" disabled selected>Seleziona un argomento</option>
              <option value="visita">Richiesta visita</option>
              <option value="disponibilita">Disponibilità posti</option>
              <option value="informazioni">Informazioni generali</option>
              <option value="lavoro">Candidatura lavoro</option>
              <option value="altro">Altro</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="cont-msg">Messaggio *</label>
            <textarea
              id="cont-msg"
              name="messaggio"
              rows="4"
              required
              placeholder="Scrivi qui il tuo messaggio…"
              class="form-input form-textarea"
            ></textarea>
          </div>

          <div class="form-check">
            <input type="checkbox" id="cont-privacy" name="privacy" required class="form-checkbox" />
            <label for="cont-privacy" class="form-check-label">
              Ho letto e accetto la
              <a href="/privacy-policy" target="_blank" class="form-link">Privacy Policy</a>
            </label>
          </div>

          <button type="submit" class="contatti-submit">
            Invia messaggio
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>

        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contatti-section {
    padding-block: 7rem;
    background-color: var(--color-avorio);
  }

  .contatti-header {
    max-width: 52rem;
    margin-bottom: 4rem;
  }

  /* ── Grid ── */
  .contatti-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .contatti-grid { grid-template-columns: 1fr 1fr; gap: 5rem; }
  }

  /* ── Info ── */
  .contatti-info-lista {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .contatti-info-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .contatti-info-icona {
    font-size: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    background-color: white;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 2px 12px -2px rgba(74, 55, 40, 0.1);
  }
  .contatti-info-titolo {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-marrone) 50%, transparent);
    margin-bottom: 0.2rem;
  }
  .contatti-info-testo {
    font-family: var(--font-sans);
    font-size: 0.97rem;
    color: var(--color-marrone);
    line-height: 1.6;
    white-space: pre-line;
  }
  .contatti-info-link {
    font-family: var(--font-sans);
    font-size: 0.97rem;
    color: var(--color-terracotta);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .contatti-info-link:hover {
    color: var(--color-terracotta-dark);
    text-decoration: underline;
  }

  .contatti-mappa {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 24px -4px rgba(74, 55, 40, 0.12);
  }

  /* ── Form ── */
  .contatti-form-wrap {
    background-color: white;
    border-radius: 1.5rem;
    padding: 2.5rem;
    box-shadow: 0 8px 40px -8px rgba(74, 55, 40, 0.12);
  }
  .contatti-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contatti-form-titolo {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-marrone);
    margin-bottom: 0.5rem;
  }
  .contatti-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background-color: var(--color-marrone);
    color: var(--color-avorio);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    padding: 0.95rem 2rem;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    width: 100%;
    margin-top: 0.5rem;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }
  .contatti-submit:hover {
    background-color: var(--color-marrone-light);
    transform: translateY(-2px);
  }
</style>