---
const spazi = [
  {
    titolo: "Le camere",
    descr: "Spazi personali arredati con cura, luminosi e accoglienti. Ogni ospite può portare i propri oggetti del cuore per sentirsi davvero a casa.",
    img: "https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=900&q=80",
    imgAlt: "Camera accogliente con luce naturale",
    grande: true,
  },
  {
    titolo: "Il giardino",
    descr: "Un giardino curato e pieno di vita, con panchine all'ombra, fiori stagionali e l'orto degli ospiti.",
    img: "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=900&q=80",
    imgAlt: "Giardino fiorito della residenza",
    grande: false,
  },
  {
    titolo: "La sala da pranzo",
    descr: "Tavoli apparecchiati ogni giorno con cura, luce naturale, profumo di cucina vera. Il pasto è un momento sociale, non una routine.",
    img: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=900&q=80",
    imgAlt: "Sala da pranzo luminosa e accogliente",
    grande: false,
  },
  {
    titolo: "La sala attività",
    descr: "Lo spazio del fare insieme: laboratori, giochi, musica, cinema. Una stanza che cambia volto ogni giorno.",
    img: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=900&q=80",
    imgAlt: "Sala attività luminosa con tavoli e sedie",
    grande: false,
  },
  {
    titolo: "Gli spazi comuni",
    descr: "Salotti, corridoi con angoli lettura, terrazzi. Luoghi progettati per incontrarsi, chiacchierare, ritrovarsi.",
    img: "https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=900&q=80",
    imgAlt: "Salotto comune con divani e luce calda",
    grande: false,
  },
  {
    titolo: "L'ingresso",
    descr: "Il primo sguardo sulla nostra casa. Caldo, luminoso, pieno di fiori freschi — perché il benvenuto inizia già dalla soglia.",
    img: "https://images.unsplash.com/photo-1560448204-603b3fc33ddc?w=900&q=80",
    imgAlt: "Ingresso accogliente della residenza",
    grande: true,
  },
];
---

<section id="spazi" class="spazi-section">
  <div class="section-wrapper">

    <!-- Header -->
    <div class="spazi-header reveal">
      <span class="tag-pill">Gli spazi</span>
      <h2 class="section-title" style="margin-top: 1rem;">
        Ogni angolo è pensato<br />
        <em style="font-style: italic; color: var(--color-salvia-dark);">per far stare bene.</em>
      </h2>
      <p class="section-subtitle" style="margin-top: 1.25rem;">
        La nostra residenza è stata progettata e arredata per essere una casa vera —
        non una struttura. Spazi luminosi, caldi, personalizzabili, dove ogni ospite
        si muove con libertà e si sente a proprio agio.
      </p>
    </div>

    <!-- Gallery asinmetrica -->
    <div class="spazi-gallery">

      <!-- Riga 1: grande sx + due piccole dx -->
      <div class="spazi-row spazi-row--1">
        <div class="spazi-card spazi-card--grande reveal">
          <div class="spazi-img-wrap">
            <img src={spazi[0].img} alt={spazi[0].imgAlt} class="spazi-img" loading="lazy" />
            <div class="spazi-overlay"></div>
            <div class="spazi-caption">
              <h3 class="spazi-caption-titolo">{spazi[0].titolo}</h3>
              <p class="spazi-caption-descr">{spazi[0].descr}</p>
            </div>
          </div>
        </div>

        <div class="spazi-col-destra">
          {spazi.slice(1, 3).map((spazio) => (
            <div class="spazi-card reveal">
              <div class="spazi-img-wrap">
                <img src={spazio.img} alt={spazio.imgAlt} class="spazi-img" loading="lazy" />
                <div class="spazi-overlay"></div>
                <div class="spazi-caption">
                  <h3 class="spazi-caption-titolo">{spazio.titolo}</h3>
                  <p class="spazi-caption-descr">{spazio.descr}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Riga 2: tre colonne uguali -->
      <div class="spazi-row spazi-row--2">
        {spazi.slice(3).map((spazio) => (
          <div class="spazi-card reveal">
            <div class="spazi-img-wrap">
              <img src={spazio.img} alt={spazio.imgAlt} class="spazi-img" loading="lazy" />
              <div class="spazi-overlay"></div>
              <div class="spazi-caption">
                <h3 class="spazi-caption-titolo">{spazio.titolo}</h3>
                <p class="spazi-caption-descr">{spazio.descr}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Nota CMS -->
    <p class="spazi-nota reveal">
      📷 Le foto vengono aggiornate regolarmente dal nostro staff — ogni stagione porta nuovi momenti da condividere.
    </p>

  </div>
</section>

<style>
  /* ── Sezione ── */
  .spazi-section {
    padding-block: 7rem;
    background-color: var(--color-avorio);
  }

  /* ── Header ── */
  .spazi-header {
    max-width: 52rem;
    margin-bottom: 4rem;
  }

  /* ── Gallery ── */
  .spazi-gallery {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  /* Riga 1 */
  .spazi-row--1 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .spazi-row--1 {
      grid-template-columns: 3fr 2fr;
    }
  }

  .spazi-col-destra {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  /* Riga 2 */
  .spazi-row--2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .spazi-row--2 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .spazi-row--2 { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Card ── */
  .spazi-card {
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 4px 24px -4px rgba(74, 55, 40, 0.12);
  }
  .spazi-card--grande .spazi-img {
    height: 460px;
  }
  @media (min-width: 768px) {
    .spazi-card--grande .spazi-img { height: 520px; }
  }

  /* ── Immagine con overlay e caption ── */
  .spazi-img-wrap {
    position: relative;
    overflow: hidden;
  }
  .spazi-img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .spazi-img-wrap:hover .spazi-img {
    transform: scale(1.05);
  }

  /* Overlay gradient dal basso */
  .spazi-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(74, 55, 40, 0.80) 0%,
      rgba(74, 55, 40, 0.20) 45%,
      transparent 100%
    );
    transition: opacity 0.4s ease;
  }

  /* Caption sovrapposta */
  .spazi-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    transform: translateY(0);
  }
  .spazi-caption-titolo {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    color: #FAF6EE;
    margin-bottom: 0.4rem;
    line-height: 1.2;
  }
  .spazi-caption-descr {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: rgba(247, 243, 236, 0.80);
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.4s ease;
  }
  .spazi-img-wrap:hover .spazi-caption-descr {
    max-height: 6rem;
    opacity: 1;
  }

  /* ── Nota ── */
  .spazi-nota {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-marrone) 55%, transparent);
    text-align: center;
    padding-top: 0.5rem;
  }
</style>