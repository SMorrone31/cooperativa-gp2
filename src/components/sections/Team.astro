---
const team = [
  {
    nome: "Suor Giovanna Ferretti",
    ruolo: "Coordinatrice",
    frase: "Ogni ospite che entra qui porta con sé una storia unica. Il mio compito è fare in modo che quella storia continui a essere vissuta con dignità e gioia.",
    img: "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=400&q=80",
    colore: "terracotta",
  },
  {
    nome: "Marco Bellini",
    ruolo: "Animatore",
    frase: "Il momento più bello del mio lavoro? Quando qualcuno che non sorrideva da settimane, durante una canzone, si illumina in viso.",
    img: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&q=80",
    colore: "salvia",
  },
  {
    nome: "Elena Conti",
    ruolo: "Animatrice e responsabile laboratori",
    frase: "Creare qualcosa con le mani dà una soddisfazione che non ha età. Lo vedo ogni giorno nei laboratori — gli occhi che si accendono quando il lavoro è finito.",
    img: "https://images.unsplash.com/photo-1580489944761-15a19d654956?w=400&q=80",
    colore: "ocra",
  },
  {
    nome: "Giuseppe Marini",
    ruolo: "Assistente alla persona",
    frase: "Questo lavoro ti insegna la pazienza, l'ascolto, il valore del tempo lento. Ogni giorno porto a casa qualcosa di più di quanto do.",
    img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80",
    colore: "salvia",
  },
  {
    nome: "Carla Negri",
    ruolo: "Assistente alla persona",
    frase: "Con alcuni ospiti ci capiamo ormai con uno sguardo. Quella complicità che si costruisce nel tempo è la cosa più preziosa di questo lavoro.",
    img: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&q=80",
    colore: "terracotta",
  },
  {
    nome: "Antonio Russo",
    ruolo: "Cuoco",
    frase: "Cucino come farebbe una nonna: con ingredienti freschi, stagionali, e tanta attenzione. Il cibo è cura — forse la più antica che esista.",
    img: "https://images.unsplash.com/photo-1577219491135-ce391730fb2c?w=400&q=80",
    colore: "ocra",
  },
  {
    nome: "Federica Lombardi",
    ruolo: "Addetta all'accoglienza",
    frase: "Sono spesso il primo volto che le famiglie incontrano. Cerco di trasmettere subito quello che si respira qui: calore, serietà, umanità.",
    img: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=400&q=80",
    colore: "salvia",
  },
  {
    nome: "Roberto Vitale",
    ruolo: "Manutentore e tuttofare",
    frase: "Mi occupo di tenere la casa in ordine, ma anche di ascoltare chi ha voglia di chiacchierare mentre lavoro. A volte sono il confidente di turno.",
    img: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=400&q=80",
    colore: "marrone",
  },
];

const coloriAccento: Record<string, string> = {
  terracotta: "var(--color-terracotta)",
  salvia:     "var(--color-salvia)",
  ocra:       "var(--color-ocra)",
  marrone:    "var(--color-marrone-light)",
};
---

<section id="team" class="team-section">
  <div class="section-wrapper">

    <!-- Header -->
    <div class="team-header reveal">
      <span class="tag-pill">Il nostro team</span>
      <h2 class="section-title" style="margin-top: 1rem;">
        Le persone che rendono<br />
        <em style="font-style: italic; color: var(--color-salvia-dark);">questa casa viva.</em>
      </h2>
      <p class="section-subtitle" style="margin-top: 1.25rem;">
        Non siamo operatori — siamo persone che hanno scelto questo lavoro con
        consapevolezza. Ognuno porta con sé una storia, una passione, un modo unico
        di prendersi cura degli altri.
      </p>
    </div>

    <!-- Griglia team -->
    <div class="team-grid">
      {team.map((persona, i) => (
        <div
          class="team-card reveal"
          style={`animation-delay: ${(i % 4) * 0.1}s;`}
        >
          <!-- Foto -->
          <div class="team-foto-wrap">
            <img
              src={persona.img}
              alt={`${persona.nome}, ${persona.ruolo}`}
              class="team-foto"
              loading="lazy"
            />
            <!-- Accent bar colorata -->
            <div
              class="team-accent-bar"
              style={`background-color: ${coloriAccento[persona.colore]};`}
            ></div>
          </div>

          <!-- Info -->
          <div class="team-info">
            <h3 class="team-nome">{persona.nome}</h3>
            <span
              class="team-ruolo"
              style={`color: ${coloriAccento[persona.colore]};`}
            >
              {persona.ruolo}
            </span>
            <blockquote class="team-frase">
              <span class="team-frase-virgolette">"</span>
              {persona.frase}
            </blockquote>
          </div>
        </div>
      ))}
    </div>

    <!-- Banner lavora con noi -->
    <div class="team-banner reveal">
      <div class="team-banner-emoji">🤝</div>
      <div class="team-banner-testo">
        <h3 class="team-banner-titolo">Vuoi entrare a far parte della nostra famiglia?</h3>
        <p class="team-banner-sub">
          Cerchiamo persone con passione, empatia e voglia di fare la differenza.
          Scrivici — anche una candidatura spontanea è sempre benvenuta.
        </p>
      </div>
      <a href="#contatti" class="team-banner-cta">
        Scrivici
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Sezione ── */
  .team-section {
    padding-block: 7rem;
    background-color: var(--color-caldo);
  }

  /* ── Header ── */
  .team-header {
    max-width: 52rem;
    margin-bottom: 4rem;
  }

  /* ── Griglia ── */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }
  @media (min-width: 640px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .team-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ── Card ── */
  .team-card {
    background-color: var(--color-avorio);
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 4px 24px -4px rgba(74, 55, 40, 0.10);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .team-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px -8px rgba(74, 55, 40, 0.18);
  }

  /* ── Foto ── */
  .team-foto-wrap {
    position: relative;
    overflow: hidden;
  }
  .team-foto {
    width: 100%;
    height: 240px;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.5s ease;
  }
  .team-card:hover .team-foto {
    transform: scale(1.04);
  }
  .team-accent-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
  }

  /* ── Info ── */
  .team-info {
    padding: 1.5rem;
  }
  .team-nome {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-marrone);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }
  .team-ruolo {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 1rem;
  }
  .team-frase {
    position: relative;
    font-family: var(--font-serif);
    font-size: 0.97rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-marrone) 72%, transparent);
    line-height: 1.65;
    margin: 0;
    padding-left: 1rem;
    border-left: 2px solid rgba(74, 55, 40, 0.12);
  }
  .team-frase-virgolette {
    font-size: 2rem;
    line-height: 0;
    vertical-align: -0.5rem;
    opacity: 0.25;
    margin-right: 0.1rem;
  }

  /* ── Banner ── */
  .team-banner {
    background-color: var(--color-avorio-dark);
    border: 1px solid color-mix(in srgb, var(--color-terracotta) 20%, transparent);
    border-radius: 1.5rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .team-banner {
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }
  }
  .team-banner-emoji {
    font-size: 2.5rem;
    flex-shrink: 0;
  }
  .team-banner-testo {
    flex: 1;
  }
  .team-banner-titolo {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-marrone);
    margin-bottom: 0.5rem;
  }
  .team-banner-sub {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-marrone) 70%, transparent);
    line-height: 1.7;
  }
  .team-banner-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-marrone);
    color: var(--color-avorio);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    padding: 0.85rem 1.75rem;
    border-radius: 9999px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }
  .team-banner-cta:hover {
    background-color: var(--color-marrone-light);
    transform: translateY(-2px);
  }
</style>