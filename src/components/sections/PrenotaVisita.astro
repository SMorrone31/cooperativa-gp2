---
---

<section id="prenota-visita" class="prenota-section">
  <div class="section-wrapper">
    <div class="prenota-grid">

      <!-- Colonna sinistra: testo invitante -->
      <div class="prenota-testo reveal">
        <span class="tag-pill">Prenota una visita</span>
        <h2 class="section-title" style="margin-top: 1rem;">
          Vieni a prendere<br />
          <em style="font-style: italic; color: var(--color-ocra-dark);">un caffè con noi.</em>
        </h2>
        <p class="prenota-sub">
          Il modo migliore per conoscere la nostra residenza è venire di persona.
          Ti aspettiamo per mostrarti gli spazi, presentarti il team e rispondere
          a tutte le tue domande — senza fretta e senza impegno.
        </p>

        <!-- Cosa aspettarsi -->
        <div class="prenota-cosa">
          {[
            { icona: "☕", testo: "Un caffè o un tè caldo appena arrivi" },
            { icona: "🚶", testo: "Una visita guidata di tutti gli spazi" },
            { icona: "👥", testo: "La conoscenza dello staff e degli ospiti" },
            { icona: "💬", testo: "Risposta a ogni tua domanda, con calma" },
            { icona: "📋", testo: "Informazioni su disponibilità e modalità" },
          ].map(({ icona, testo }) => (
            <div class="prenota-cosa-item">
              <span class="prenota-cosa-icona">{icona}</span>
              <span class="prenota-cosa-testo">{testo}</span>
            </div>
          ))}
        </div>

        <!-- Orari visite -->
        <div class="prenota-orari">
          <p class="prenota-orari-titolo">📅 Visite disponibili</p>
          <p class="prenota-orari-testo">
            Dal lunedì al venerdì, 9:00–12:00 e 14:00–17:00<br />
            Sabato mattina su appuntamento
          </p>
        </div>
      </div>

      <!-- Colonna destra: form -->
      <div class="prenota-form-wrap reveal">
        <form
          name="prenota-visita"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="prenota-form"
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="prenota-visita" />
          <p style="display:none;">
            <label>Non compilare: <input name="bot-field" /></label>
          </p>

          <h3 class="prenota-form-titolo">Prenota la tua visita</h3>
          <p class="prenota-form-sub">Ti ricontattiamo entro 24 ore per confermare.</p>

          <!-- Nome -->
          <div class="form-group">
            <label class="form-label" for="prenota-nome">Nome e cognome *</label>
            <input
              type="text"
              id="prenota-nome"
              name="nome"
              required
              placeholder="Mario Rossi"
              class="form-input"
            />
          </div>

          <!-- Telefono -->
          <div class="form-group">
            <label class="form-label" for="prenota-tel">Numero di telefono *</label>
            <input
              type="tel"
              id="prenota-tel"
              name="telefono"
              required
              placeholder="+39 333 000 0000"
              class="form-input"
            />
          </div>

          <!-- Email -->
          <div class="form-group">
            <label class="form-label" for="prenota-email">Email</label>
            <input
              type="email"
              id="prenota-email"
              name="email"
              placeholder="mario@email.it"
              class="form-input"
            />
          </div>

          <!-- Data preferita -->
          <div class="form-group">
            <label class="form-label" for="prenota-data">Data preferita</label>
            <input
              type="date"
              id="prenota-data"
              name="data"
              class="form-input"
            />
          </div>

          <!-- Messaggio -->
          <div class="form-group">
            <label class="form-label" for="prenota-msg">Vuoi dirci qualcosa?</label>
            <textarea
              id="prenota-msg"
              name="messaggio"
              rows="3"
              placeholder="Domande, curiosità, situazioni particolari da raccontarci…"
              class="form-input form-textarea"
            ></textarea>
          </div>

          <!-- Privacy -->
          <div class="form-check">
            <input type="checkbox" id="prenota-privacy" name="privacy" required class="form-checkbox" />
            <label for="prenota-privacy" class="form-check-label">
              Ho letto e accetto la
              <a href="/privacy-policy" target="_blank" class="form-link">Privacy Policy</a>
            </label>
          </div>

          <!-- Submit -->
          <button type="submit" class="prenota-submit">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            Prenota ora — è gratuito
          </button>

        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .prenota-section {
    padding-block: 7rem;
    background-color: var(--color-avorio-dark);
  }

  /* ── Grid ── */
  .prenota-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .prenota-grid { grid-template-columns: 1fr 1fr; gap: 5rem; }
  }

  /* ── Testo ── */
  .prenota-sub {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.85;
    color: color-mix(in srgb, var(--color-marrone) 78%, transparent);
    margin-top: 1.25rem;
    margin-bottom: 2rem;
  }

  .prenota-cosa {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }
  .prenota-cosa-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .prenota-cosa-icona {
    font-size: 1.3rem;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }
  .prenota-cosa-testo {
    font-family: var(--font-sans);
    font-size: 0.97rem;
    color: var(--color-marrone);
  }

  .prenota-orari {
    background-color: white;
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--color-ocra);
  }
  .prenota-orari-titolo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--color-marrone);
    margin-bottom: 0.4rem;
  }
  .prenota-orari-testo {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: color-mix(in srgb, var(--color-marrone) 70%, transparent);
    line-height: 1.65;
  }

  /* ── Form ── */
  .prenota-form-wrap {
    background-color: white;
    border-radius: 1.5rem;
    padding: 2.5rem;
    box-shadow: 0 8px 40px -8px rgba(74, 55, 40, 0.14);
  }
  .prenota-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .prenota-form-titolo {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-marrone);
    margin-bottom: 0.1rem;
  }
  .prenota-form-sub {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-marrone) 55%, transparent);
    margin-bottom: 0.5rem;
  }

  /* ── Campi ── */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-label {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-marrone);
    letter-spacing: 0.02em;
  }
  .form-input {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-marrone);
    background-color: var(--color-caldo);
    border: 1.5px solid color-mix(in srgb, var(--color-marrone) 16%, transparent);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }
  .form-input:focus {
    border-color: var(--color-salvia);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-salvia) 20%, transparent);
  }
  .form-textarea {
    resize: vertical;
    min-height: 90px;
  }

  /* ── Checkbox ── */
  .form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .form-checkbox {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.15rem;
    accent-color: var(--color-salvia);
    flex-shrink: 0;
    cursor: pointer;
  }
  .form-check-label {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: color-mix(in srgb, var(--color-marrone) 70%, transparent);
    line-height: 1.5;
  }
  .form-link {
    color: var(--color-terracotta);
    font-weight: 600;
    text-decoration: underline;
  }

  /* ── Submit ── */
  .prenota-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background-color: var(--color-terracotta);
    color: white;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.05rem;
    padding: 1rem 2rem;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 24px -4px rgba(196, 123, 90, 0.4);
    width: 100%;
    margin-top: 0.5rem;
  }
  .prenota-submit:hover {
    background-color: var(--color-terracotta-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px -4px rgba(196, 123, 90, 0.5);
  }
</style>